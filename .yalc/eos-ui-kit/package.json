{
  "name": "eos-ui-kit",
  "version": "0.17.0",
  "description": "UI component library for the Estate Operations System",
  "private": false,
  "type": "module",
  "main": "dist/eos-ui-kit.umd.js",
  "module": "dist/eos-ui-kit.es.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate-icons": "tsx src/scripts/generate-icons.ts && npm run format",
    "lint": "eslint src --ext .ts,.tsx,.vue && stylelint src/**/*.{css,scss}",
    "lint:fix": "eslint src --ext .ts,.tsx,.vue --fix && stylelint src/**/*.{css,scss} --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,json,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,vue,json,css,scss}\""
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "vite-svg-loader": "^5.1.1",
    "yalc": "^1.0.0-pre.53"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "src/**/*.{json}": [
      "prettier --write"
    ]
  },
  "yalcSig": "b3f3d8523888043101ad8188ea3b0edc"
}
