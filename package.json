{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "gen:api": "openapi-typescript ./src/api/openapi.json -o ./src/api/api.d.ts",
    "lint": "eslint src --ext .ts,.tsx,.vue && stylelint src/**/*.{css,scss}",
    "lint:fix": "eslint src --ext .ts,.tsx,.vue --fix && stylelint src/**/*.{css,scss} --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,json,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,vue,json,css,scss}\"",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "eos-ui-kit": "1.0.0",
    "nuxt": "^4.2.1",
    "primevue": "^4.5.4",
    "sass-embedded": "^1.99.0",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@primevue/nuxt-module": "^4.5.4",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-vue": "^9.27.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.12.0",
    "prettier": "^3.1.1",
    "stylelint": "^14.16.1",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-standard-scss": "^4.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "src/**/*.{json}": [
      "prettier --write"
    ]
  }
}
